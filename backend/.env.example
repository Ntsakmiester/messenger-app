# Copy this file to .env and fill in real values

# Postgres connection string (use a managed DB like Supabase, RDS, or Neon for production)
DATABASE_URL="postgresql://user:password@localhost:5432/messenger"

# Redis - used for Socket.io cross-server pub/sub (critical for multi-region scaling)
# and for tracking online presence
REDIS_URL="redis://localhost:6379"

# JWT secret - generate with `openssl rand -hex 32`
JWT_SECRET="replace-with-a-long-random-secret"
JWT_EXPIRES_IN="30d"

# Server
PORT=4000
NODE_ENV=development

# Which region this server instance is running in (for logging/routing awareness)
REGION="af-south-1"

# SMS/OTP provider (e.g. Twilio) - required for real phone verification in production
SMS_PROVIDER_API_KEY=""
SMS_PROVIDER_FROM_NUMBER=""

# Media storage (S3-compatible, e.g. AWS S3, Cloudflare R2, Backblaze B2)
S3_BUCKET=""
S3_REGION=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
